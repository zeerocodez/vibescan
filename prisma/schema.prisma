generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  tier           String    @default("free")
  scanCount      Int       @default(0)
  createdAt      DateTime  @default(now())
  scans          Scan[]
}

model Scan {
  id             String    @id @default(uuid())
  userId         String?
  repoUrl        String
  repoName       String?
  repoOwner      String?
  status         String    @default("queued") // queued, scanning, completed, failed
  overallScore   Int?
  grade          String?
  durationMs     Int?
  totalFiles     Int       @default(0)
  totalLines     Int       @default(0)
  createdAt      DateTime  @default(now())
  user           User?     @relation(fields: [userId], references: [id])
  findings       Finding[]
}

model Finding {
  id             String    @id @default(uuid())
  scanId         String
  category       String
  severity       String
  title          String
  description    String?
  filePath       String?
  scan           Scan      @relation(fields: [scanId], references: [id], onDelete: Cascade)
}

model AgentAlert {
  id             String    @id @default(uuid())
  projectId      String?
  command        String
  blocked        Boolean   @default(true)
  createdAt      DateTime  @default(now())
}
